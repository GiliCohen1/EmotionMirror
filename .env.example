# Copy this file to .env and fill in the values for local development.
# In production, set these as environment variables (never commit .env).

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# --- Database ---
# SQLite (default for local dev):
DATABASE_URL=sqlite+aiosqlite:///./emotionmirror.db
# PostgreSQL (production example):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/emotionmirror

# --- Model ---
MODEL_CHECKPOINT=model/checkpoints/efficientnet_b0_fer2013_best.pt
MODEL_ONNX=model/checkpoints/efficientnet_b0_fer2013.onnx
USE_ONNX=false

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

# --- CORS (JSON array of allowed origins) ---
# ALLOWED_ORIGINS=["https://your-app.vercel.app"]
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
